rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTrade(data) {
      return data.userId == request.auth.uid
        && data.ticker is string && data.ticker.size() > 0 && data.ticker.size() <= 10
        && data.entryPrice is number && data.entryPrice >= 0
        && data.exitPrice is number && data.exitPrice >= 0
        && data.shares is number && data.shares > 0
        && data.strategy is string && data.strategy.size() > 0 && data.strategy.size() <= 50
        && data.notes is string && data.notes.size() <= 1000
        && data.pnl is number;
    }

    function isValidPreferences(data) {
      return data.markets is list
        && data.markets.size() <= 10
        && data.robinhoodOnly is bool
        && (!('brokerage' in data) || data.brokerage == null || (data.brokerage is string && (data.brokerage == 'none' || data.brokerage == 'robinhood' || data.brokerage == 'lightspeed' || data.brokerage == 'interactivebrokers')))
        && (!('robinhoodToken' in data) || data.robinhoodToken == null || data.robinhoodToken is string)
        && (!('lightspeedKey' in data) || data.lightspeedKey == null || data.lightspeedKey is string)
        && (!('ibkrUrl' in data) || data.ibkrUrl == null || data.ibkrUrl is string);
    }

    function isValidExecutionState(data) {
      return ('empty' in data && data.empty == true)
        || (data.ticker is string
            && data.entryPrice is number
            && data.exitPrice is number
            && data.shares is number
            && data.pnl is number);
    }

    match /users/{userId}/trades/{tradeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(tradeId)
        && isValidTrade(incoming())
        && (incoming().timestamp == request.time || incoming().timestamp == null);
      allow update: if isOwner(userId)
        && isValidId(tradeId)
        && isValidTrade(incoming())
        && incoming().timestamp == existing().timestamp;
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/preferences/{prefId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && isValidId(prefId)
        && isValidPreferences(incoming());
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/executionState/{docId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && isValidId(docId)
        && isValidExecutionState(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
